{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "default": {},
  "type": "object",
  "properties": {
    "系统": {
      "default": {},
      "type": "object",
      "properties": {
        "日期": {
          "default": "待初始化",
          "type": "string"
        },
        "时间": {
          "default": "待初始化",
          "type": "string"
        },
        "当前地点": {
          "default": "待初始化",
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "时夏": {
                  "default": "待初始化",
                  "type": "string"
                },
                "栗原": {
                  "default": "待初始化",
                  "type": "string"
                },
                "{{user}}": {
                  "default": "待初始化",
                  "type": "string"
                }
              }
            },
            {
              "type": "string",
              "const": "待初始化"
            }
          ]
        }
      }
    },
    "时夏": {
      "default": {},
      "type": "object",
      "properties": {
        "爱隐藏值": {
          "default": 200,
          "type": "number",
          "description": "0-200，初始 200=完全隐藏。随剧情递减，越低越藏不住爱。到 0 时时夏会直接向{{user}}表白，必须让{{user}}做出选择"
        },
        "做爱次数": {
          "type": "number"
        },
        "对栗原": {
          "default": "待初始化",
          "type": "string",
          "description": "if 线剧情：时夏对栗原的话，以及对当前正文的评价。仅在时夏或栗原有一方在场时更新"
        },
        "对{{user}}的内心话": {
          "default": "待初始化",
          "type": "string"
        }
      }
    },
    "栗原": {
      "default": {},
      "type": "object",
      "properties": {
        "灰心度": {
          "type": "number",
          "description": "0-200，初始 0=完全不灰心。栗原知道时夏和{{user}}曾是要好的朋友，但认定爱要靠自己争取。数值越高越想放弃，到 200 时会直接向{{user}}表白，必须让{{user}}做出选择"
        },
        "做爱次数": {
          "type": "number"
        },
        "对时夏": {
          "default": "待初始化",
          "type": "string",
          "description": "if 线剧情：栗原对时夏的话，以及对当前正文的评价。仅在时夏或栗原有一方在场时更新"
        },
        "对{{user}}的心理话": {
          "default": "待初始化",
          "type": "string"
        }
      }
    },
    "{{user}}的选择": {
      "default": {},
      "type": "object",
      "properties": {
        "时夏": {
          "type": "boolean"
        },
        "栗原": {
          "type": "boolean"
        }
      }
    }
  }
}